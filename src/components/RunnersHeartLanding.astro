---
import type { RunnersHeartPageContent } from '../data/runnersHeartPage';

interface Props {
  content: RunnersHeartPageContent;
  appStoreUrl: string;
}

const { content, appStoreUrl } = Astro.props;
const supportHref = content.locale === 'ko' ? '/runners-heart/support/ko/' : '/runners-heart/support/';
const privacyHref = content.locale === 'ko' ? '/runners-heart/privacy/ko/' : '/runners-heart/privacy/';
---

<section class="hero">
  <div class="hero-topbar">
    <div class="hero-copy">
      <span class="eyebrow">{content.heroEyebrow}</span>
      <div class="hero-title-row">
        <img src="/assets/images/projects/runners-heart-icon.png" alt={`${content.appName} app icon`} class="app-icon" />
        <div>
          <h1>{content.appName}</h1>
          <p class="tagline">{content.heroTagline}</p>
        </div>
      </div>
      <p class="hero-description">{content.heroDescription}</p>

      <div class="hero-actions">
        <a href={appStoreUrl} class="btn btn-primary" target="_blank" rel="noopener noreferrer">{content.primaryCta}</a>
        <a href="#demo" class="btn btn-secondary">{content.secondaryCta}</a>
      </div>

      <div class="chip-row">
        {content.chips.map((chip) => (
          <span class="chip">{chip}</span>
        ))}
      </div>
    </div>

    <nav class="locale-switch" aria-label="Language selector">
      {content.localeLinks.map((link) => (
        <a href={link.href} class:list={[ 'locale-pill', link.active && 'is-active' ]}>{link.label}</a>
      ))}
    </nav>
  </div>
</section>

<section id="demo" class="panel demo-section">
  <div class="section-heading">
    <span class="section-kicker">{content.demoKicker}</span>
    <h2>{content.demoTitle}</h2>
    <p>{content.demoDescription}</p>
  </div>

  <div class="demo-grid">
    <div class="video-shell">
      <video
        class="demo-video"
        controls
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster={content.videoPoster}
      >
        <source src={content.videoSrc} type="video/mp4" />
        Your browser does not support the video tag.
      </video>
    </div>

    <div class="demo-copy">
      <div class="demo-callout">
        <strong>{content.demoCalloutTitle}</strong>
        <p>{content.demoCalloutBody}</p>
      </div>

      <ul class="highlight-list">
        {content.highlightPoints.map((point) => (
          <li>{point}</li>
        ))}
      </ul>
    </div>
  </div>
</section>

<section class="features">
  <div class="section-heading">
    <span class="section-kicker">{content.featureKicker}</span>
    <h2>{content.featureTitle}</h2>
    <p>{content.featureDescription}</p>
  </div>

  <div class="feature-grid">
    {content.features.map((feature) => (
      <article class="feature-card">
        <div class="feature-icon" aria-hidden="true">{feature.icon}</div>
        <h3>{feature.title}</h3>
        <p>{feature.description}</p>
      </article>
    ))}
  </div>
</section>

<section class="panel gallery-section">
  <div class="section-heading section-heading-wide">
    <span class="section-kicker">{content.galleryKicker}</span>
    <h2>{content.galleryTitle}</h2>
    <p>{content.galleryDescription}</p>
  </div>

  <div class="gallery-grid">
    {content.galleryItems.map((item) => (
      <figure class="gallery-card">
        <div class="gallery-image-shell">
          <img src={item.src} alt={item.alt} loading="eager" />
        </div>
        <figcaption class="gallery-copy">
          <span class="gallery-device">{item.device}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </figcaption>
      </figure>
    ))}
  </div>
</section>

<section class="panel summary-section">
  <div class="summary-copy">
    <span class="section-kicker">{content.summaryKicker}</span>
    <h2>{content.summaryTitle}</h2>
    <p>{content.summaryDescription}</p>
  </div>

  <div class="summary-stats">
    {content.summaryStats.map((stat) => (
      <div class="stat-card">
        <span class="stat-value">{stat.value}</span>
        <span class="stat-label">{stat.label}</span>
      </div>
    ))}
  </div>
</section>

<section class="cta">
  <h2>{content.ctaTitle}</h2>
  <p>{content.ctaDescription}</p>
  <a href={appStoreUrl} class="btn btn-primary cta-button" target="_blank" rel="noopener noreferrer">{content.ctaButton}</a>
</section>

<section class="footer-links">
  <a href={supportHref}>{content.supportLabel}</a>
  <span class="separator">·</span>
  <a href={privacyHref}>{content.privacyLabel}</a>
</section>

<style>
  :root {
    --rh-ink: #3f1c27;
    --rh-red: #9e3147;
    --rh-coral: #f39a72;
    --rh-peach: #ffe8dd;
    --rh-surface: rgba(255, 255, 255, 0.72);
    --rh-border: rgba(255, 255, 255, 0.7);
    --rh-shadow: 0 18px 48px rgba(76, 31, 41, 0.12);
  }

  .hero,
  .panel,
  .feature-card,
  .gallery-card,
  .cta {
    border: 1px solid var(--rh-border);
    box-shadow: var(--rh-shadow);
    backdrop-filter: blur(24px) saturate(145%);
    -webkit-backdrop-filter: blur(24px) saturate(145%);
  }

  .hero {
    position: relative;
    overflow: hidden;
    padding: 56px;
    margin-bottom: 32px;
    border-radius: 28px;
    background:
      radial-gradient(circle at top right, rgba(243, 154, 114, 0.32), transparent 26%),
      radial-gradient(circle at bottom left, rgba(158, 49, 71, 0.12), transparent 24%),
      linear-gradient(135deg, rgba(255, 245, 240, 0.95), rgba(255, 255, 255, 0.8));
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.25), rgba(255, 255, 255, 0.02));
    pointer-events: none;
  }

  .hero-topbar {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
  }

  .hero-copy {
    min-width: 0;
  }

  .eyebrow,
  .section-kicker,
  .gallery-device {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.78);
    color: var(--rh-red);
    font-size: 0.86rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .eyebrow,
  .section-kicker {
    margin-bottom: 18px;
  }

  .locale-switch {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .locale-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.8);
    color: #714855;
    border: 1px solid rgba(158, 49, 71, 0.08);
    font-size: 0.92rem;
    font-weight: 700;
  }

  .locale-pill.is-active {
    background: linear-gradient(135deg, var(--rh-red), #bf4960);
    color: #fff;
  }

  .locale-pill:hover {
    border-bottom: 1px solid transparent;
    color: var(--rh-red);
  }

  .locale-pill.is-active:hover {
    color: #fff;
  }

  .hero-title-row {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 18px;
  }

  .app-icon {
    width: 112px;
    height: 112px;
    border-radius: 26px;
    box-shadow: 0 18px 34px rgba(158, 49, 71, 0.18);
    flex-shrink: 0;
  }

  h1 {
    font-size: clamp(2.6rem, 5vw, 4rem);
    line-height: 0.95;
    color: var(--rh-ink);
    margin: 0 0 8px;
  }

  .tagline {
    color: var(--rh-red);
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0;
  }

  .hero-description,
  .section-heading p,
  .summary-copy p,
  .cta p,
  .demo-callout p,
  .feature-card p,
  .gallery-copy p {
    color: #5d4650;
    font-size: 1rem;
  }

  .hero-description {
    max-width: 720px;
    margin-bottom: 24px;
    font-size: 1.06rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 20px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 22px;
    border-radius: 999px;
    font-weight: 700;
    border: 1px solid transparent;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease, color 0.2s ease;
    text-decoration: none;
  }

  .btn:hover {
    transform: translateY(-2px);
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--rh-red), #bf4960);
    color: #fff;
    box-shadow: 0 12px 24px rgba(158, 49, 71, 0.22);
  }

  .btn-primary:hover {
    color: #fff;
    box-shadow: 0 16px 28px rgba(158, 49, 71, 0.28);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.9);
    color: var(--rh-ink);
    border-color: rgba(158, 49, 71, 0.12);
  }

  .btn-secondary:hover {
    color: var(--rh-red);
    box-shadow: 0 14px 28px rgba(76, 31, 41, 0.08);
  }

  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.78);
    color: #714855;
    font-size: 0.92rem;
    border: 1px solid rgba(158, 49, 71, 0.08);
  }

  .panel,
  .cta {
    background: var(--rh-surface);
    border-radius: 24px;
  }

  .panel {
    padding: 32px;
    margin-bottom: 32px;
  }

  .section-heading {
    max-width: 720px;
    margin-bottom: 24px;
  }

  .section-heading-wide {
    max-width: none;
  }

  .section-heading h2,
  .summary-copy h2,
  .cta h2 {
    color: var(--rh-ink);
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    margin: 0 0 10px;
  }

  .demo-grid,
  .summary-section {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 24px;
    align-items: center;
  }

  .video-shell {
    padding: 12px;
    border-radius: 24px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(255, 241, 235, 0.9));
    border: 1px solid rgba(158, 49, 71, 0.08);
  }

  .demo-video {
    display: block;
    width: 100%;
    border-radius: 18px;
    background: #120b0f;
    box-shadow: 0 16px 36px rgba(63, 28, 39, 0.18);
  }

  .demo-copy {
    display: grid;
    gap: 18px;
  }

  .demo-callout {
    padding: 20px;
    border-radius: 20px;
    background: linear-gradient(135deg, rgba(243, 154, 114, 0.12), rgba(158, 49, 71, 0.06));
    border: 1px solid rgba(158, 49, 71, 0.1);
  }

  .demo-callout strong {
    display: block;
    margin-bottom: 8px;
    color: var(--rh-ink);
    font-size: 1.02rem;
  }

  .highlight-list {
    list-style: none;
    display: grid;
    gap: 12px;
    padding: 0;
    margin: 0;
  }

  .highlight-list li {
    position: relative;
    padding-left: 22px;
    color: #5d4650;
  }

  .highlight-list li::before {
    content: '•';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--rh-red);
    font-weight: 900;
  }

  .features {
    margin-bottom: 32px;
  }

  .feature-grid,
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .feature-card,
  .gallery-card {
    background: rgba(255, 255, 255, 0.66);
    border-radius: 22px;
    padding: 24px;
  }

  .feature-icon {
    width: 52px;
    height: 52px;
    display: grid;
    place-items: center;
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(243, 154, 114, 0.22), rgba(158, 49, 71, 0.12));
    font-size: 1.5rem;
    margin-bottom: 16px;
  }

  .feature-card h3,
  .gallery-copy h3 {
    color: var(--rh-ink);
    font-size: 1.08rem;
    margin-bottom: 8px;
  }

  .gallery-card {
    padding: 14px;
  }

  .gallery-image-shell {
    padding: 12px;
    border-radius: 20px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 241, 235, 0.85));
    border: 1px solid rgba(158, 49, 71, 0.08);
    margin-bottom: 14px;
  }

  .gallery-image-shell img {
    width: 100%;
    display: block;
    border-radius: 14px;
    box-shadow: 0 12px 24px rgba(63, 28, 39, 0.12);
  }

  .gallery-copy {
    padding: 4px 6px 6px;
  }

  .gallery-device {
    margin-bottom: 10px;
    font-size: 0.76rem;
  }

  .summary-section {
    padding: 32px;
  }

  .summary-stats {
    display: grid;
    gap: 14px;
  }

  .stat-card {
    padding: 20px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(158, 49, 71, 0.08);
  }

  .stat-value {
    display: block;
    color: var(--rh-red);
    font-size: 1.2rem;
    font-weight: 800;
    margin-bottom: 4px;
  }

  .stat-label {
    color: #6b4f59;
    font-size: 0.95rem;
  }

  .cta {
    text-align: center;
    padding: 44px 32px;
    margin-bottom: 28px;
    background:
      radial-gradient(circle at top center, rgba(243, 154, 114, 0.18), transparent 30%),
      linear-gradient(135deg, rgba(255, 247, 243, 0.92), rgba(255, 255, 255, 0.82));
  }

  .cta p {
    max-width: 620px;
    margin: 0 auto 20px;
  }

  .cta-button {
    min-width: 180px;
  }

  .footer-links {
    text-align: center;
    padding: 12px 0 4px;
    color: #90707b;
  }

  .footer-links a {
    color: var(--rh-red);
    display: inline-block;
    padding: 6px 10px;
  }

  .footer-links a:hover {
    color: var(--rh-ink);
  }

  .separator {
    display: inline-block;
    margin: 0 8px;
    color: rgba(144, 112, 123, 0.7);
  }

  @supports not ((backdrop-filter: blur(24px))) {
    .hero,
    .panel,
    .feature-card,
    .gallery-card,
    .cta {
      background: rgba(255, 255, 255, 0.92);
    }
  }

  @media (max-width: 900px) {
    .hero,
    .panel,
    .summary-section,
    .cta {
      padding: 28px;
    }

    .feature-grid,
    .gallery-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .demo-grid,
    .summary-section {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 24px;
      border-radius: 22px;
    }

    .hero-topbar,
    .hero-title-row {
      align-items: flex-start;
      flex-direction: column;
      gap: 16px;
    }

    .locale-switch {
      justify-content: flex-start;
    }

    .app-icon {
      width: 88px;
      height: 88px;
      border-radius: 22px;
    }

    .panel,
    .summary-section,
    .cta {
      padding: 22px;
      border-radius: 20px;
    }

    .hero-actions {
      flex-direction: column;
    }

    .btn {
      width: 100%;
    }

    .feature-grid,
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
