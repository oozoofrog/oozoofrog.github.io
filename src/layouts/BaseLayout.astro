---
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
  image?: string;
  type?: string;
  publishedDate?: string;
  lang?: string;
  ogLocale?: string;
}
const {
  title = 'oozoofrog',
  description = 'Building iOS & macOS apps and open-source developer tools.',
  canonical,
  noindex = false,
  image,
  type = 'website',
  publishedDate,
  lang = 'ko',
  ogLocale = lang === 'en' ? 'en_US' : 'ko_KR',
} = Astro.props;
const canonicalUrl = canonical ?? Astro.url?.toString();
const ogImage = image ?? new URL('/assets/images/og-default.png', Astro.site).toString();
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://oozoofrog.dev';

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "oozoofrog",
  "description": "Building iOS & macOS apps and open-source developer tools.",
  "url": siteUrl,
  "author": {
    "@type": "Person",
    "name": "oozoofrog",
    "url": `${siteUrl}/about/`
  }
};
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSense from '../components/AdSense.astro';
import Analytics from '../components/Analytics.astro';
import CookieConsent from '../components/CookieConsent.astro';
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
  <link rel="icon" href="/favicon.ico" />
  <Analytics />
  <AdSense />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={type} />
  {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="oozoofrog" />
  <meta property="og:locale" content={ogLocale} />
  {publishedDate && <meta property="article:published_time" content={publishedDate} />}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  {type === 'website' && <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />}
</head>
<body>
  <Header />
  <main class="wrapper">
    <slot />
  </main>
  <Footer />
  <CookieConsent />
</body>
</html>
