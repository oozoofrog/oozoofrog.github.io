---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import RunnersHeartLanding from '../../../components/RunnersHeartLanding.astro';
import { runnersHeartPageKo } from '../../../data/runnersHeartPage';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://oozoofrog.dev';
const appStoreUrl = 'https://apps.apple.com/us/app/runners-heart/id6758222219';

const appJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'RunnersHeart',
  operatingSystem: 'iOS, watchOS',
  applicationCategory: 'HealthApplication',
  description:
    'Apple Watch 햅틱, 개인화된 존 계산, 경로 추적, iPhone 분석 화면까지 갖춘 심박수 존 러닝 코치 앱.',
  image: `${siteUrl}/assets/images/projects/runners-heart-icon.png`,
  screenshot: `${siteUrl}/assets/images/projects/runners-heart-zone-gauge-ko-poster.jpg`,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  downloadUrl: appStoreUrl,
};
---

<BaseLayout
  title={runnersHeartPageKo.seoTitle}
  description={runnersHeartPageKo.seoDescription}
  image={`${siteUrl}/assets/images/projects/runners-heart-zone-gauge-ko-poster.jpg`}
  lang="ko"
>
  <script type="application/ld+json" set:html={JSON.stringify(appJsonLd)} />
  <RunnersHeartLanding content={runnersHeartPageKo} appStoreUrl={appStoreUrl} />
</BaseLayout>
