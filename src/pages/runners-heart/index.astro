---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RunnersHeartLanding from '../../components/RunnersHeartLanding.astro';
import { runnersHeartPageEn } from '../../data/runnersHeartPage';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://oozoofrog.dev';
const appStoreUrl = 'https://apps.apple.com/us/app/runners-heart/id6758222219';

const appJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'RunnersHeart',
  operatingSystem: 'iOS, watchOS',
  applicationCategory: 'HealthApplication',
  description:
    'Heart rate zone running coach with Apple Watch haptics, personalized zones, route tracking, and iPhone workout analysis.',
  image: `${siteUrl}/assets/images/projects/runners-heart-icon.png`,
  screenshot: `${siteUrl}/assets/images/projects/runners-heart-zone-gauge-poster.jpg`,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  downloadUrl: appStoreUrl,
};
---

<BaseLayout
  title={runnersHeartPageEn.seoTitle}
  description={runnersHeartPageEn.seoDescription}
  image={`${siteUrl}/assets/images/projects/runners-heart-zone-gauge-poster.jpg`}
  lang="en"
>
  <script type="application/ld+json" set:html={JSON.stringify(appJsonLd)} />
  <RunnersHeartLanding content={runnersHeartPageEn} appStoreUrl={appStoreUrl} />
</BaseLayout>
