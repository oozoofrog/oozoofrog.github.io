---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.public !== false);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(post);
const wordCount = post.body?.split(/\s+/).filter(Boolean).length ?? 0;
const shouldNoindex = wordCount < 150;
---

<BlogPost
  title={post.data.title}
  date={post.data.date}
  categories={post.data.categories}
  description={post.data.summary ?? `${post.data.title} | 우주개구리 블로그`}
  noindex={shouldNoindex}
>
  <Content />
</BlogPost>
